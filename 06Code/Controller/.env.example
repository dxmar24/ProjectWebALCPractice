APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=America/Bogota
APP_KEY=CHANGE_ME_GENERATE_A_64_CHARACTER_RANDOM_VALUE
FRONTEND_ORIGINS=https://projectwebalcpractice-frontend.onrender.com,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5173,http://localhost:5173
GOOGLE_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com
GOOGLE_AUTO_REGISTER_ROLE=director
GOOGLE_AUTO_REGISTER_BRANCH_ID=1
# Optional: restrict access to one Google Workspace domain.
# GOOGLE_ALLOWED_DOMAIN=your-school-domain.com

# Supabase PostgreSQL connection.
# If the direct host is IPv6-only on your computer, use the transaction pooler.
DB_CONNECTION=pgsql
DB_HOST=aws-1-us-west-2.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=CHANGE_ME
DB_SSLMODE=require
